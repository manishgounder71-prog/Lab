# ── LLM Provider (AI Agent Debate) ──────────────────────────────────────────
# At least one is required for live AI-generated C-suite debate responses.
# Gemini is tried first; OpenAI is the fallback.
GEMINI_API_KEY=your-google-gemini-key
OPENAI_API_KEY=your-openai-key

# ── Band SDK Cloud Platform (app.band.ai) ───────────────────────────────────
# Required only if running agents live on the Band cloud platform.
# Each C-suite agent needs its own ID and API key from app.band.ai.
CISO_AGENT_ID=your-ciso-agent-uuid
CISO_API_KEY=your-ciso-api-key
CFO_AGENT_ID=your-cfo-agent-uuid
CFO_API_KEY=your-cfo-api-key
CEO_AGENT_ID=your-ceo-agent-uuid
CEO_API_KEY=your-ceo-api-key

# ── Local Development / Custom Server URLs ──────────────────────────────────
# (Optional) Override if you are running a local/staging instance of the Band platform
BAND_REST_URL=http://localhost:3000
BAND_WS_URL=ws://localhost:3000/api/v1/socket/websocket
